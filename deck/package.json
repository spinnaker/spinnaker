{
  "main": "./dist/bundle.js",
  "name": "deck",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/spinnaker/spinnaker.git"
  },
  "publishConfig": {
    "registry": "http://artifacts.netflix.com/api/npm/npm-local"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24"
  },
  "private": true,
  "scripts": {
    "clean": "lerna run clean --parallel",
    "fixup": "scripts/monorepo_fixup.sh",
    "build": "pnpm --filter deck-app build",
    "lint": "eslint --max-warnings=0 --ext js,jsx,ts,tsx packages",
    "start": "sh ./start.sh",
    "start-dev-server": "pnpm --filter deck-app start-dev-server",
    "dev:experimental": "cd packages/app && npm run dev:experimental",
    "test": "NODE_OPTIONS=--openssl-legacy-provider karma start --single-run",
    "modules": "./scripts/buildModules.js",
    "prettier": "prettier --write 'packages/**/*.{js,jsx,ts,tsx,html,css,less}'",
    "prettier:check": "prettier --check 'packages/**/*.{js,jsx,ts,tsx,html,css,less}'",
    "functional": "pnpm --dir test/functional install && pnpm --dir test/functional build && pnpm --dir test/functional test",
    "functional:debug": "pnpm --dir test/functional install && pnpm --dir test/functional build && pnpm --dir test/functional open",
    "storybook": "start-storybook -p 9001"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@spinnaker/eslint-plugin": "workspace:^",
    "@types/jasmine": "3.6.9",
    "@types/node": "16.4.13",
    "@typescript-eslint/eslint-plugin": "8.32.0",
    "@typescript-eslint/parser": "8.32.0",
    "angular": "1.8.3",
    "angular-mocks": "1.8.3",
    "babel-loader": "8.1.0",
    "buffer": "^6.0.3",
    "enzyme": "3.11.0",
    "enzyme-adapter-react-16": "1.15.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-webpack-plugin": "5.0.2",
    "globals": "^17.2.0",
    "jasmine": "3.7.0",
    "jasmine-core": "3.7.1",
    "jquery": "3.5.1",
    "karma": "6.3.16",
    "karma-chrome-launcher": "3.1.0",
    "karma-jasmine": "4.0.1",
    "karma-junit-reporter": "2.0.1",
    "karma-mocha-reporter": "2.2.5",
    "karma-sourcemap-loader": "0.3.8",
    "karma-super-dots-reporter": "0.2.0",
    "karma-webpack": "5.0.0",
    "kleur": "^4.1.4",
    "lerna": "^9.0.0",
    "prettier": "2.1.2",
    "process": "^0.11.10",
    "prompts": "^2.4.1",
    "rimraf": "2.6.1",
    "setimmediate": "1.0.5",
    "sisteransi": "^1.0.5",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5",
    "yargs": "^17.0.1"
  },
  "optionalDependencies": {
    "fsevents": "2.3.2"
  },
  "lint-staged": {
    "packages/**/*.{js,jsx,ts,tsx}": "eslint --fix",
    "packages/**/*.{js,jsx,ts,tsx,html,css,less}": "prettier --write"
  }
}
