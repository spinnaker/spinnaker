  "devDependencies": {
    "@spinnaker/eslint-plugin": "workspace:^3.0.2",
    "@spinnaker/mocks": "workspace:1.0.7",
    "@spinnaker/scripts": "workspace:^0.4.0",
    "@types/classnames": "2.2.0",
    "@types/enzyme": "3.10.3",
    "@types/lodash": "4.14.64",
    "@types/react-bootstrap": "0.32.5",
    "@types/react": "16.14.10",
