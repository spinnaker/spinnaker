{
  "kind": "ReplicaSetList",
  "apiVersion": "apps/v1",
  "metadata": {
    "resourceVersion": "1"
  },
  "items": [
    {
      "metadata": {
        "name": "my-replicaset",
        "namespace": "test-namespace",
        "ownerReferences": [
          {
            "apiVersion": "apps/v1",
            "kind": "Deployment",
            "name": "my-deployment"
          }
        ]
      },
      "spec": {
        "replicas": 2,
        "selector": {
          "matchLabels": {
            "app": "my-app"
          }
        },
        "template": {
          "spec": {
            "containers": [
              {
                "name": "my-pod-container",
                "image": "my-pod-container-image"
              }
            ]
          }
        }
      }
    }
  ]
}
