{
  "kind": "ReplicaSetList",
  "apiVersion": "apps/v1",
  "metadata": {
    "resourceVersion": "1"
  },
  "items": [
    {
      "metadata": {
        "name": "my-replicaset",
        "namespace": "test-namespace"
      },
      "spec": {
        "replicas": 2,
        "selector": {
          "matchLabels": {
            "app": "my-app"
          }
        },
        "template": {
          "spec": {
            "containers": [
              {
                "name": "my-pod-container",
                "image": "my-pod-container-image"
              }
            ]
          }
        }
      }
    },
    {
      "metadata": {
        "name": "my-replicaset",
        "namespace": "test-namespace2"
      },
      "spec": {
        "replicas": 2,
        "selector": {
          "matchLabels": {
            "app": "my-app"
          }
        },
        "template": {
          "spec": {
            "containers": [
              {
                "name": "my-pod-container",
                "image": "my-pod-container-image"
              }
            ]
          }
        }
      }
    }
  ]
}
