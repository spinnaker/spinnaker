{
  "variables": {
    "proxmox_url": null,
    "proxmox_username": null,
    "proxmox_password": "",
    "proxmox_node": null,
    "proxmox_clone_vm_id": null,
    "proxmox_vm_name": null,
    "proxmox_vm_id": "",
    "proxmox_storage": "local-lvm",
    "proxmox_cloud_init_storage": "local",
    "proxmox_ssh_username": "ubuntu",
    "proxmox_cores": "2",
    "proxmox_memory": "2048",
    "proxmox_full_clone": "true",
    "proxmox_insecure_skip_tls_verify": "false",
    "proxmox_cpu":"x86-64-v2-AES",
    "proxmox_bios":"ovmf",
    "appversion": "",
    "build_host": "",
    "build_info_url": "",
    "repository": "",
    "package_type": "deb",
    "packages": "",
    "upgrade": "",
    "configDir": null
  },
  "builders": [{
    "type": "proxmox-clone",
    "proxmox_url": "{{user `proxmox_url`}}",
    "username": "{{user `proxmox_username`}}",
    "password": "{{user `proxmox_password`}}",
    "insecure_skip_tls_verify": "{{user `proxmox_insecure_skip_tls_verify`}}",
    "node": "{{user `proxmox_node`}}",
    "clone_vm_id": "{{user `proxmox_clone_vm_id`}}",
    "cpu_type":"{{ user `proxmox_cpu` }}",
    "machine":"q35",
    "os": "l26",
    "bios":"{{ user `proxmox_bios` }}",
    "vm_id": "{{user `proxmox_vm_id`}}",
    "vm_name": "{{user `proxmox_vm_name`}}",
    "full_clone": "{{user `proxmox_full_clone`}}",
    "cores": "{{user `proxmox_cores`}}",
    "memory": "{{user `proxmox_memory`}}",
    "scsi_controller": "virtio-scsi-pci",
    "qemu_agent": false,
    "cloud_init": false,
    "cloud_init_disk_type":"scsi",
    "cloud_init_storage_pool": "{{user `proxmox_cloud_init_storage`}}",
    "communicator": "ssh",
    "ssh_username": "{{user `proxmox_ssh_username`}}",
    "ssh_agent_auth": false,
    "network_adapters":[ {
      "model": "virtio",
      "bridge": "vmbr0",
      "firewall":false
    }],
    "ssh_timeout": "10m",
    "template_name": "{{user `proxmox_vm_name`}}",
    "template_description": "appversion: {{user `appversion`}}, build_host: {{user `build_host`}}, build_info_url: {{user `build_info_url`}}"
  }],
  "provisioners": [{
    "type": "shell",
    "script": "{{user `configDir`}}/install_packages.sh",
    "pause_before":"1m",
    "max_retries":3,
    "environment_vars": [
      "repository={{user `repository`}}",
      "package_type={{user `package_type`}}",
      "packages=qemu-guest-agent,{{user `packages`}}",
      "upgrade={{user `upgrade`}}"
    ]
  }]
}
